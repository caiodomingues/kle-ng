{
  "name": "kle-ng",
  "version": "0.41.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:docs": "vitepress dev docs",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:docs": "vitepress build docs",
    "preview": "vite preview",
    "test:unit": "vitest run --reporter=github-actions",
    "test:unit:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:headless": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project chromium",
    "test:e2e:update": "playwright test --update-snapshots=all",
    "test:e2e:update-chromium": "playwright test --project chromium --update-snapshots=all",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --log-level silent --write src/ e2e/ docs/"
  },
  "dependencies": {
    "@adamws/kle-serial": "github:adamws/kle-serial2#v0.19.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@jscad/modeling": "^2.13.0",
    "@jscad/stl-serializer": "^2.1.23",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "decimal.js": "^10.6.0",
    "ergogen": "^4.2.1",
    "fflate": "^0.8.3",
    "fuse.js": "^7.4.2",
    "js-yaml": "^4.2.0",
    "json5": "^2.2.3",
    "lz-string": "^1.5.0",
    "makerjs": "^0.19.2",
    "medium-zoom": "^1.1.0",
    "pinia": "^3.0.4",
    "polygon-clipping": "^0.15.7",
    "three": "^0.185.1",
    "vue": "^3.5.39"
  },
  "overrides": {
    "ergogen": {
      "kle-serial": "github:adamws/kle-serial2#v0.19.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/file-saver": "^2.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "dxf-json": "^0.14.1",
    "eslint": "^10.6.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "prettier": "3.9.4",
    "sass": "^1.101.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vite-svg-loader": "^5.1.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  }
}
